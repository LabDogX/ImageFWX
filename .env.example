# ============================================
# ImageMagick WebGUI Configuration
# ============================================
# Copy this file to .env and modify as needed:
# cp .env.example .env

# ============================================
# PORTS CONFIGURATION (for local development)
# ============================================
# Default: 3000 (frontend), 8000 (backend)
# Custom: 3012 (frontend) → 8012 (backend) [auto-mapped!]
FRONTEND_PORT=3012
BACKEND_PORT=8012

# API port for frontend to connect (must match BACKEND_PORT)
NEXT_PUBLIC_API_PORT=8012

# After changing ports:
# docker compose down
# docker compose build --no-cache
# docker compose up -d

# ============================================
# SECURITY (CHANGE IN PRODUCTION!)
# ============================================
SECRET_KEY=
JWT_SECRET=
POSTGRES_PASSWORD=

# Generate secure keys:
# openssl rand -hex 32

# ============================================
# AUTHENTICATION
# ============================================
# Require login to use the app
# true  = secure default: nobody can upload or view images without an account.
# false = open mode: anyone can use the app WITHOUT logging in, and images
#         uploaded anonymously are visible to ALL other anonymous visitors of
#         this server. Only set to false for a private/trusted environment.
REQUIRE_LOGIN=true

# Allow new user registration
# Set to false to prevent new signups
ALLOW_REGISTRATION=false

# ============================================
# REVERSE PROXY CONFIGURATION
# ============================================
# For a reverse proxy, add your public browser origin(s). Lucky deployments
# forward the whole site to FRONTEND_PORT; ImageFWX proxies /api internally.
# Example: ALLOWED_ORIGINS=https://imagemagick.example.com,http://localhost:3012
ALLOWED_ORIGINS=

# ============================================
# DATABASE (Internal - Don't change)
# ============================================
# Docker Compose constructs this from POSTGRES_PASSWORD. Set explicitly only
# for a non-Docker development database.
DATABASE_URL=

# ============================================
# REDIS (Internal - Don't change)
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# GOOGLE OAUTH (Optional)
# ============================================
# Leave empty to disable Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Setup instructions:
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID
# 3. Add authorized redirect URI: https://yourdomain.com/api/auth/google/callback

# ============================================
# IMAGE PROCESSING
# ============================================
# Maximum upload size in MB
MAX_UPLOAD_SIZE_MB=100

# Default output format (webp, jpeg, png, avif)
DEFAULT_OUTPUT_FORMAT=webp

# Default quality (1-100)
DEFAULT_QUALITY=85

# ImageMagick timeout in seconds
IMAGEMAGICK_TIMEOUT=300

# ImageMagick memory limit
IMAGEMAGICK_MEMORY_LIMIT=2GB

# ============================================
# AI BACKGROUND REMOVAL (rembg)
# ============================================
# Model used for background removal.
# isnet-general-use (default) gives cleaner edges than u2net at similar speed.
# Other options: u2net, u2net_human_seg (people), silueta.
# Note: only isnet-general-use is pre-downloaded in the image; others are
# fetched on first use at runtime.
REMBG_MODEL=isnet-general-use

# ONNX Runtime CPU threads. 0 = use all cores (best speed on dedicated boxes).
# Set to a low number (e.g. 2) on a shared or weak VPS to cap CPU usage.
ONNX_THREADS=0

# ============================================
# HISTORY
# ============================================
# How long to keep processed images (hours)
HISTORY_RETENTION_HOURS=24

# ============================================
# NAS PHOTO BROWSER (disabled by default)
# ============================================
# The source is mounted read-only at NAS_SOURCE_DIR. Imports are copied into
# /app/uploads; never point PROCESSED_DIR at the source directory.
NAS_BROWSER_ENABLED=false
NAS_SOURCE_DIR=/mnt/photos
NAS_MAX_IMPORT_FILES=100

# Storage locations used by the one Compose file. Leave these as the named
# volume defaults for a simple Docker-only deployment. To use NAS folders, set
# all four values to absolute host paths and enable NAS_BROWSER_ENABLED above.
# Example paths with Chinese characters should remain quoted in .env.
UPLOADS_STORAGE=uploads
PROCESSED_STORAGE=processed
TEMP_STORAGE=temp
NAS_SOURCE_STORAGE=nas_source

# ============================================
# TIMEZONE
# ============================================
TZ=UTC
